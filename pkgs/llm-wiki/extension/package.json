{
  "name": "llm-wiki",
  "version": "0.1.0",
  "description": "A Pi extension for local wiki capture, search, scaffolding, and linting",
  "private": true,
  "type": "module",
  "keywords": [
    "pi-package"
  ],
  "pi": {
    "extensions": [
      "./index.ts"
    ]
  },
  "peerDependencies": {
    "@mariozechner/pi-ai": "*",
    "@mariozechner/pi-coding-agent": "*",
    "@sinclair/typebox": "*"
  },
  "peerDependenciesMeta": {
    "@mariozechner/pi-ai": {
      "optional": true
    },
    "@mariozechner/pi-coding-agent": {
      "optional": true
    },
    "@sinclair/typebox": {
      "optional": true
    }
  },
  "dependencies": {
    "js-yaml": "^4.1.0",
    "neverthrow": "^8.2.0"
  }
}
